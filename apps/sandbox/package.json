    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.8",
    "@tsconfig/svelte": "^5.0.4",
    "engine": "workspace:*",
    "eslint": "^9.30.0",
    "eslint-plugin-svelte": "^3.10.1",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "svelte": "^5.34.7",
    "svelte-check": "^4.2.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vitest-canvas-mock": "^0.3.3"
