{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "tsconfig/svelte.json",
  "compilerOptions": {
    "types": ["@testing-library/jest-dom"],
    "paths": {
      "#/*": [
        "./src/*",
        "../../packages/engine/src/*" // allow to import from engine in the sandbox
      ],
    },
    "tsBuildInfoFile": ".tsbuild/test.tsbuildinfo"
  },
  "include": ["src", "tests"]
}
