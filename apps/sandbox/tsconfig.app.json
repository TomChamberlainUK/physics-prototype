{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "tsconfig/svelte.json",
  "compilerOptions": {
    "paths": {
      "#/*": [
        "./src/*",
        "../../packages/engine/src/*" // allow to import from engine in the sandbox
      ],
    },
    "tsBuildInfoFile": ".tsbuild/app.tsbuildinfo"
  },
  "include": ["src"]
}
