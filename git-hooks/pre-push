#!/bin/sh

AUTHOR_EMAIL=$(git config user.email)
AUTHOR_NAME=$(git config user.name)
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
MAJOR_SEPARATOR="==============================="
MINOR_SEPARATOR="-------------------------------"
EXIT_CODE=0

run_check() {
  name="$1"
  shift

  echo "$MINOR_SEPARATOR"
  echo "⏳ Running $name..."
  echo "$MINOR_SEPARATOR"

  "$@"
  exit_code=$?

  echo "$MINOR_SEPARATOR"
  if [ $exit_code -ne 0 ]; then
    echo "❌ $name failed"
    EXIT_CODE=1
  else
    echo "✅ $name passed"
  fi
  echo "$MINOR_SEPARATOR"

  return $exit_code
}

print_summary() {
  name="$1"
  exit_code="$2"
  if [ $exit_code -ne 0 ]; then
    echo "❌ $name"
  else
    echo "✅ $name"
  fi
}

echo "$MAJOR_SEPARATOR"
echo "🔍 Running pre-push checks"
echo "$MINOR_SEPARATOR"
echo "🌱 Branch: $BRANCH_NAME"
echo "👤 Author: $AUTHOR_NAME <$AUTHOR_EMAIL>"
echo "$MAJOR_SEPARATOR"

run_check "Lint" pnpm run lint
LINT_EXIT_CODE=$?
run_check "Typecheck" pnpm run typecheck
TYPECHECK_EXIT_CODE=$?
run_check "Unit Tests" pnpm run test
UNIT_TEST_EXIT_CODE=$?
run_check "Build" pnpm run build
BUILD_EXIT_CODE=$?

echo "$MAJOR_SEPARATOR"
echo "📋 Check summary:"

echo "$MINOR_SEPARATOR"
print_summary "Lint" $LINT_EXIT_CODE
print_summary "Typecheck" $TYPECHECK_EXIT_CODE
print_summary "Unit Tests" $UNIT_TEST_EXIT_CODE
print_summary "Build" $BUILD_EXIT_CODE
echo "$MINOR_SEPARATOR"

if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ Checks failed"
else
  echo "🚀 All checks passed"
fi
echo "$MAJOR_SEPARATOR"

exit $EXIT_CODE
